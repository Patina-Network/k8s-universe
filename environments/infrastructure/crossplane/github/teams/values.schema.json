{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GitHub Teams and Members Schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["providerConfigName", "teams"],
  "properties": {
    "providerConfigName": {
      "type": "string",
      "description": "The Crossplane ProviderConfig name for GitHub."
    },
    "teams": {
      "type": "array",
      "description": "List of GitHub teams to be managed.",
      "items": {
        "type": "object",
        "required": ["name", "privacy", "members"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "description": "The name of the GitHub team."
          },
          "privacy": {
            "type": "string",
            "enum": ["secret", "closed"],
            "description": "The level of privacy for the team."
          },
          "members": {
            "type": "array",
            "description": "List of members assigned to this specific team.",
            "items": {
              "type": "object",
              "required": ["username", "role"],
              "additionalProperties": false,
              "properties": {
                "username": {
                  "type": "string",
                  "description": "The GitHub handle of the user."
                },
                "role": {
                  "type": "string",
                  "enum": ["maintainer", "member"],
                  "description": "The role assigned to the user within the team."
                }
              }
            }
          }
        }
      }
    }
  }
}
